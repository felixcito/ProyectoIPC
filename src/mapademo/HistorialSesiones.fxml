<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane id="AnchorPane" prefHeight="438.0" prefWidth="377.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.HistorialSesionesController">
    <stylesheets>
        <URL value="@historialsesiones.css" />
    </stylesheets>
   <children>
      <VBox prefHeight="400.0" prefWidth="299.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="User Session History" />
            <TableView fx:id="sessionTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colDate" prefWidth="75.0" text="Date" />
                <TableColumn fx:id="colDuration" prefWidth="75.0" text="Duration" />
                  <TableColumn fx:id="colImported" prefWidth="75.0" text="Imported" />
                  <TableColumn fx:id="colViewed" prefWidth="75.0" text="Viewed" />
                  <TableColumn fx:id="colAnnotations" prefWidth="75.0" text="Annotations" />
              </columns>
            </TableView>
            <HBox prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Label fx:id="lblTotalImported" text="Total Imported: -" />
                  <Label fx:id="lblTotalViewed" text="Total Viewed: -" />
                  <Label fx:id="lblTotalAnnotations" text="Total Annotations: -" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Button fx:id="btnClose" alignment="CENTER" mnemonicParsing="false" onAction="#handleClose" text="Close" textAlignment="CENTER" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
