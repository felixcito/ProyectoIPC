<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="850.0" spacing="15.0" style="-fx-background-color: #1e1e1e;" stylesheets="@../resources/estilos.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.HistorialSesionesController">
   <children>
      <Label styleClass="registration-title" text="SESSION HISTORY" />
      
      <HBox alignment="CENTER_RIGHT" prefWidth="650.0" spacing="10.0">
         <children>
            <Label styleClass="register-text" text="Filter by:" />
            <ComboBox fx:id="comboFiltro" prefWidth="150.0" styleClass="register-input" />
         </children>
         <VBox.margin>
            <Insets right="20.0" />
         </VBox.margin>
      </HBox>
      
      <VBox fx:id="chartContainer" prefHeight="250.0" VBox.vgrow="ALWAYS" />

      <TableView fx:id="sessionTable" prefHeight="200.0" prefWidth="650.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colDate" prefWidth="100.0" text="Date" />
          <TableColumn fx:id="colTime" prefWidth="80.0" text="Time" />
          <TableColumn fx:id="colDuration" prefWidth="100.0" text="Duration" />
          <TableColumn fx:id="colImported" prefWidth="90.0" text="Imported" />
          <TableColumn fx:id="colViewed" prefWidth="90.0" text="Viewed" />
          <TableColumn fx:id="colAnnotations" prefWidth="110.0" text="Annotations" />
        </columns>
      </TableView>
      
      <HBox alignment="CENTER" spacing="40.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 15;">
         <children>
            <Label fx:id="lblTotalImported" styleClass="register-text" text="Total Imported: 0" />
            <Label fx:id="lblTotalViewed" styleClass="register-text" text="Total Viewed: 0" />
            <Label fx:id="lblTotalAnnotations" styleClass="register-text" text="Total Annotations: 0" />
         </children>
         <padding>
            <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
         </padding>
      </HBox>
      
      <Button fx:id="btnClose" cancelButton="true" mnemonicParsing="false" onAction="#handleClose" prefWidth="150.0" styleClass="login-button" text="CLOSE" />
   </children>
   <padding>
      <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
   </padding>
</VBox>