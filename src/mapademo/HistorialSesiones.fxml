<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="750.0" spacing="20.0" style="-fx-background-color: #1e1e1e;" stylesheets="@../resources/estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.HistorialSesionesController">
   <children>
      <Label styleClass="registration-title" text="SESSION HISTORY" />
      
      <TableView fx:id="sessionTable" prefHeight="300.0" prefWidth="650.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colDate" prefWidth="150.0" text="Date" />
          <TableColumn fx:id="colDuration" prefWidth="100.0" text="Duration" />
          <TableColumn fx:id="colImported" prefWidth="100.0" text="Imported" />
          <TableColumn fx:id="colViewed" prefWidth="100.0" text="Viewed" />
          <TableColumn fx:id="colAnnotations" prefWidth="120.0" text="Annotations" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      
      <HBox alignment="CENTER" spacing="40.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 15;">
         <children>
            <Label fx:id="lblTotalImported" styleClass="register-text" text="Total Imported: 0" />
            <Label fx:id="lblTotalViewed" styleClass="register-text" text="Total Viewed: 0" />
            <Label fx:id="lblTotalAnnotations" styleClass="register-text" text="Total Annotations: 0" />
         </children>
         <padding>
            <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
         </padding>
      </HBox>
      
      <Button fx:id="btnClose" cancelButton="true" mnemonicParsing="false" onAction="#handleClose" prefWidth="150.0" styleClass="login-button" text="CLOSE" />
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
