<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="borderPane" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxmlapplication.controller.MainViewController">
   <center>
      <Pane BorderPane.alignment="CENTER" />
   </center>
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <MenuBar>
              <menus>
                <Menu text="_Archivo">
                  <items>
                    <MenuItem onAction="#salir" text="_Salir" />
                  </items>
                </Menu>
                  <Menu mnemonicParsing="false" text="_Lanzar">
                    <items>
                      <MenuItem text="_Amazon" />
                        <MenuItem text="_Blogger" />
                        <MenuItem text="_Ebay" />
                        <MenuItem text="_Facebook" />
                        <MenuItem text="_Google" />
                    </items>
                  </Menu>
                <Menu text="_Opciones">
                  <items>
                        <Menu text="_ComprarEn">
                          <items>
                              <RadioMenuItem fx:id="compraAmazon" selected="true" text="_Amazon">
                                 <toggleGroup>
                                    <ToggleGroup fx:id="grupoTiendas" />
                                 </toggleGroup></RadioMenuItem>
                              <RadioMenuItem fx:id="compraEbay" text="_Ebay" toggleGroup="$grupoTiendas" />
                          </items>
                        </Menu>
                  </items>
                </Menu>
              </menus>
            </MenuBar>
            <ToolBar>
              <items>
                <Button fx:id="amazon" alignment="CENTER" maxHeight="40.0" maxWidth="40.0" mnemonicParsing="false" onAction="#lanzarWeb" prefHeight="40.0" prefWidth="40.0">
                     <graphic>
                        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../icons/amazon.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button fx:id="blogger" mnemonicParsing="false" onAction="#seleccionarBlog">
                     <graphic>
                        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../icons/bing.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button fx:id="ebay" mnemonicParsing="false" onAction="#lanzarWeb">
                     <graphic>
                        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../icons/ebay.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button fx:id="facebook" mnemonicParsing="false" onAction="#escribeUser">
                     <graphic>
                        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../icons/facebook.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button fx:id="google" mnemonicParsing="false" onAction="#lanzarWeb">
                     <graphic>
                        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../icons/googlePlus.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
              </items>
            </ToolBar>
         </children>
      </VBox>
   </top>
   <bottom>
      <HBox BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="labelEstado" />
         </children>
         <padding>
            <Insets left="5.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>
